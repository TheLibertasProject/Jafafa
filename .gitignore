# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────────────────────────
.next/
out/
build/

# ── Environment & secrets ─────────────────────────────────────────────────────
# Never commit real env files. Commit .env.example as a safe template instead.
.env
.env.*
!.env.example

# Private keys, certificates, credentials
*.pem
*.key
*.p8
*.p12
*.pfx
*.jks
*.keystore
credentials.json
secrets.json
service-account*.json
*_rsa
*_rsa.pub
*_dsa
*_ed25519
*_ecdsa

# ── Package-manager logs & debug ──────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
lerna-debug.log*
*.log

# ── Testing & coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/

# ── Build artefacts & caches ──────────────────────────────────────────────────
dist/
.turbo/
.cache/
.parcel-cache/
*.tsbuildinfo
next-env.d.ts

# ── OS artefacts ──────────────────────────────────────────────────────────────

# macOS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.DocumentRevisions-V100
.fseventsd
.TemporaryItems

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.fuse_hidden*
.nfs*

# ── Editors & IDEs ────────────────────────────────────────────────────────────

# VS Code — ignore personal workspace state but allow shared settings
.vscode/*.log
.vscode/settings.json
.vscode/launch.json
# Uncomment the line below to ignore the entire .vscode directory instead:
# .vscode/

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.ipr
*.iws

# Vim / Neovim
*.swp
*.swo
*~
Session.vim
.netrwhist

# Emacs
\#*\#
.\#*
*.elc

# ── Deployment ────────────────────────────────────────────────────────────────
.vercel/

# ── Miscellaneous ─────────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.tgz
